# electron-builder quirk fix for `@alejandria/mac` (PR-4D, issue #77).
#
# electron-builder's transitive deps break `electron-store` resolution
# when `legacy-peer-deps=true` is forced at the user level. We pin
# both flags at the project level so:
#   - CI runs and developer machines produce the same package-lock.json
#   - electron-builder's own peer-dep checks run against the project
#     resolution (not the user's global npm config)
# Verified by `__tests__/npmrc.test.ts`.

legacy-peer-deps=false
strict-peer-dependencies=false
